build/
out/
dist/

# Real resumes. This one matters: a resume is PII -- name, phone, address,
# employment history. Nobody should accidentally commit theirs to a public repo.
# examples/*.yaml is the exception: those are fictional.
resume.yaml
*_resume.yaml
*-resume.yaml
my*.yaml
!examples/*.yaml

